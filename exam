2.MERGE SORT 
#include <stdio.h>

void merge(int A[], int p, int q, int r)
{
    int i=p, j=q+1, k=p;
    int temp[50];

    while(i<=q && j<=r)
    {
        if(A[i] <= A[j])
            temp[k++] = A[i++];
        else
            temp[k++] = A[j++];
    }

    while(i<=q)
        temp[k++] = A[i++];

    while(j<=r)
        temp[k++] = A[j++];

    for(i=p;i<=r;i++)
        A[i] = temp[i];
}

void mergesort(int A[], int p, int r)
{
    int q;

    if(p < r)
    {
        q = (p+r)/2;

        mergesort(A,p,q);
        mergesort(A,q+1,r);
        merge(A,p,q,r);
    }
}

int main()
{
    int A[50], n, i;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(i=0;i<n;i++)
        scanf("%d",&A[i]);

    mergesort(A,0,n-1);

    printf("Sorted array:\n");

    for(i=0;i<n;i++)
        printf("%d ",A[i]);

    return 0;
}


















3.QUICK SORT

#include <stdio.h>
void quicksort(int A[], int p, int r);
int partition(int A[], int p, int r);

int partition(int A[], int p, int r)
{
    int x = A[r];
    int i = p - 1;
    int j, temp;

    for(j=p;j<=r-1;j++)
    {
        if(A[j] <= x)
        {
            i++;
            temp = A[i];
            A[i] = A[j];
            A[j] = temp;
        }
    }
 temp = A[i+1];
    A[i+1] = A[r];
    A[r] = temp;

    return i+1;
}

void quicksort(int A[], int p, int r)
{
    int q;

    if(p < r)
    {
        q = partition(A,p,r);

        quicksort(A,p,q-1);
        quicksort(A,q+1,r);
    }
}

int main()
{
    int A[50], n, i;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements:\n");

    for(i=0;i<n;i++)
        scanf("%d",&A[i]);

    quicksort(A,0,n-1);

    printf("Sorted array:\n");

    for(i=0;i<n;i++)
        printf("%d ",A[i]);

    return 0;
}


















4.FRACTIONAL KNAPSACK 

#include <stdio.h>

int main()
{
    int n,i,j;
    float W[20], V[20], cost[20];
    float M, SW=0, SP=0, frac;

    printf("Enter number of items: ");
    scanf("%d",&n);

    printf("Enter Profit and Weight:\n");

    for(i=0;i<n;i++)
    {
        scanf("%f %f",&V[i],&W[i]);
        cost[i] = V[i]/W[i];
    }

    for(i=0;i<n-1;i++)
    {
        for(j=i+1;j<n;j++)
        {
            if(cost[i] < cost[j])
            {
                float temp;

                temp=cost[i]; cost[i]=cost[j]; cost[j]=temp;
                temp=V[i]; V[i]=V[j]; V[j]=temp;
                temp=W[i]; W[i]=W[j]; W[j]=temp;
            }
        }
    }

    printf("Enter knapsack capacity: ");
    scanf("%f",&M);

    i=0;

    while(i<n)
    {
        if(SW + W[i] <= M)
        {
            SW += W[i];
            SP += V[i];
        }
        else
        {
            frac = (M-SW)/W[i];
            SW += W[i]*frac;
            SP += V[i]*frac;
            break;
        }

        i++;
    }

    printf("Maximum Profit = %.2f",SP);

    return 0;
}















6.flyod warshall 

#include <stdio.h>
#define INF 99999
#define MAX 20

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int dist[MAX][MAX], next[MAX][MAX];

    printf("Enter adjacency matrix:\n");
    printf("(Enter %d for no edge)\n", INF);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &dist[i][j]);

            if (i == j)
                next[i][j] = -1;
            else if (dist[i][j] != INF)
                next[i][j] = j;
            else
                next[i][j] = -1;
        }
    }

    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                if (dist[i][k] != INF && dist[k][j] != INF) {
                    if (dist[i][j] > dist[i][k] + dist[k][j]) {
                        dist[i][j] = dist[i][k] + dist[k][j];
                        next[i][j] = next[i][k];
                    }
                }
            }
        }
    }

    printf("\nShortest Distance Matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (dist[i][j] == INF)
                printf("INF ");
            else
                printf("%d ", dist[i][j]);
        }
        printf("\n");
    }

    printf("\nShortest paths between all pairs:\n");

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i != j) {
                printf("\nPath from %d to %d: ", i, j);

                if (next[i][j] == -1) {
                    printf("No path");
                    continue;
                }

                int u = i;
                printf("%d", u);

                while (u != j) {
                    u = next[u][j];
                    printf(" -> %d", u);
                }

                printf("  (Cost: %d)", dist[i][j]);
            }
        }
    }

    return 0;
}































7. LCS :


#include <stdio.h>
#include <string.h>
#define MAX 100

int max(int a, int b) {
    return (a > b) ? a : b;
}

int main() {
    char str1[MAX], str2[MAX];
    int dp[MAX][MAX];
    int i, j;

    printf("Enter first string: ");
    scanf("%s", str1);

    printf("Enter second string: ");
    scanf("%s", str2);

    int m = strlen(str1);
    int n = strlen(str2);

    for (i = 0; i <= m; i++) {
        for (j = 0; j <= n; j++) {
            if (i == 0 || j == 0) {
                dp[i][j] = 0;
            } else if (str1[i - 1] == str2[j - 1]) {
                dp[i][j] = dp[i - 1][j - 1] + 1;
            } else {
                dp[i][j] = max(dp[i - 1][j], dp[i][j - 1]);
            }
        }
    }

    int index = dp[m][n];
    char lcs[index + 1];
    lcs[index] = '\0';

    i = m;
    j = n;

    while (i > 0 && j > 0) {
        if (str1[i - 1] == str2[j - 1]) {
            lcs[index - 1] = str1[i - 1];
            i--;
            j--;
            index--;
        } else if (dp[i - 1][j] >= dp[i][j - 1]) {
            i--;
        } else {
            j--;
        }
    }

    printf("Length of LCS: %d\n", dp[m][n]);
    printf("LCS: %s\n", lcs);

    return 0;
}
















8.N Queen 

#include <stdio.h>
#include <stdlib.h>

int x[50];
int count = 0;
int N, maxSolutions;

int isSafe(int k, int i) {
    for (int j = 0; j < k; j++) {
        if (x[j] == i || abs(x[j] - i) == abs(j - k))
            return 0;
    }
    return 1;
}

void nQueens(int k) {
    if (count >= maxSolutions) return;

    for (int i = 0; i < N; i++) {
        if (isSafe(k, i)) {
            x[k] = i;

            if (k == N - 1) {
                for (int j = 0; j < N; j++)
                    printf("%d ", x[j] + 1);
                printf("\n");

                count++;
                if (count >= maxSolutions) return;
            } else {
                nQueens(k + 1);
            }
        }
    }
}

int main() {
    printf("Enter number of queens: ");
    scanf("%d", &N);

    printf("Enter number of solutions to print: ");
    scanf("%d", &maxSolutions);

    nQueens(0);

    if (count == 0)
        printf("No solutions found.\n");

    return 0;
}


























9.SUM OF SUBSETS 
#include <stdio.h>
#define MAX 50

int n, target;
int set[MAX];
int solution[MAX];

void printSolution() {
    printf("{ ");
    for (int i = 0; i < n; i++) {
        if (solution[i] == 1) {
            printf("%d ", set[i]);
        }
    }
    printf("}\n");
}

void sumOfSubsets(int index, int currentSum) {
    if (currentSum == target) {
        printSolution();
        return;
    }

    if (index >= n || currentSum > target) {
        return;
    }

    solution[index] = 1;
    sumOfSubsets(index + 1, currentSum + set[index]);

    solution[index] = 0;
    sumOfSubsets(index + 1, currentSum);
}

int main() {
    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &set[i]);
    }

    printf("Enter target sum: ");
    scanf("%d", &target);

    for (int i = 0; i < n; i++) {
        solution[i] = 0;
    }

    printf("\nSubsets with sum %d are:\n", target);
    sumOfSubsets(0, 0);

    return 0;
}




















10.15 PUZZLE 

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#define N 4
#define MAX 100

int goal[N][N];

typedef struct Node {
    int mat[N][N], x, y, g, h;
    struct Node *parent;
    char move[10];
} Node;

int cost(int a[N][N]) {
    int c = 0;
    for(int i=0;i<N;i++)
        for(int j=0;j<N;j++)
            if(a[i][j] && a[i][j]!=goal[i][j])
                c++;
    return c;
}

Node* newNode(int mat[N][N], int x, int y, int nx, int ny, int g, Node* p, char *m) {
    Node* n = (Node*)malloc(sizeof(Node));
    memcpy(n->mat, mat, sizeof(n->mat));
    int t = n->mat[x][y];
    n->mat[x][y] = n->mat[nx][ny];
    n->mat[nx][ny] = t;
    n->x = nx; n->y = ny;
    n->g = g; n->h = cost(n->mat);
    n->parent = p;
    strcpy(n->move, m);
    return n;
}

Node* pq[MAX];
int sz = 0;

void push(Node* n){ pq[sz++] = n; }

Node* pop(){
    int m=0;
    for(int i=1;i<sz;i++)
        if(pq[i]->g+pq[i]->h < pq[m]->g+pq[m]->h)
            m=i;
    Node* t=pq[m];
    pq[m]=pq[--sz];
    return t;
}

int isGoal(int a[N][N]) {
    return cost(a)==0;
}

void print(int a[N][N]){
    for(int i=0;i<N;i++){
        for(int j=0;j<N;j++) printf("%2d ",a[i][j]);
        printf("\n");
    }
    printf("\n");
}

void path(Node* r){
    if(!r) return;
    path(r->parent);

    static int s=1;
    printf("Step %d (%s):\n", s++, r->move);
    print(r->mat);
}

void solve(int a[N][N], int x, int y){
    push(newNode(a,x,y,x,y,0,NULL,"START"));

    int dx[]={1,-1,0,0}, dy[]={0,0,1,-1};
    char *mv[]={"DOWN","UP","RIGHT","LEFT"};

    while(sz){
        Node* cur=pop();

        if(isGoal(cur->mat)){
            printf("\nSolution Found!\n\n");
            path(cur);
            return;
        }

        for(int i=0;i<4;i++){
            int nx=cur->x+dx[i], ny=cur->y+dy[i];
            if(nx>=0&&ny>=0&&nx<N&&ny<N)
                push(newNode(cur->mat,cur->x,cur->y,nx,ny,cur->g+1,cur,mv[i]));
        }
    }
}

int main(){
    int a[N][N], x, y;

    printf("Enter initial state:\n");
    for(int i=0;i<N;i++)
        for(int j=0;j<N;j++){
            scanf("%d",&a[i][j]);
            if(a[i][j]==0) x=i,y=j;
        }

    printf("Enter goal state:\n");
    for(int i=0;i<N;i++)
        for(int j=0;j<N;j++)
            scanf("%d",&goal[i][j]);

    solve(a,x,y);

    return 0;
}































5.kruskals algorithm 


#include <stdio.h>

int parent[20];

int find(int i)
{
    while(parent[i])
        i = parent[i];
    return i;
}

int union_set(int i,int j)
{
    if(i!=j)
    {
        parent[j]=i;
        return 1;
    }
    return 0;
}

int main()
{
    int n,i,j,a,b,u,v,min,mincost=0;
    int cost[20][20];

    printf("Enter number of vertices: ");
    scanf("%d",&n);

    printf("Enter cost matrix:\n");
    for(i=1;i<=n;i++)
        for(j=1;j<=n;j++)
        {
            scanf("%d",&cost[i][j]);
            if(cost[i][j]==0)
                cost[i][j]=999;
        }

    for(i=1;i<=n;i++)
        parent[i]=0;

    while(1)
    {
        min=999;
        for(i=1;i<=n;i++)
        {
            for(j=1;j<=n;j++)
            {
                if(cost[i][j] < min)
                {
                    min=cost[i][j];
                    a=u=i;
                    b=v=j;
                }
            }
        }

        u=find(u);
        v=find(v);

        if(union_set(u,v))
        {
            printf("Edge %d-%d cost=%d\n",a,b,min);
            mincost += min;
        }

        cost[a][b]=cost[b][a]=999;

        if(min==999)
            break;
    }

    printf("Minimum cost = %d",mincost);

    return 0;}

